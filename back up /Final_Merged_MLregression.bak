   "source": [
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import r2_score, mean_absolute_error\n",
    "\n",
    "# Create the pipeline\n",
    "lr_pipeline = Pipeline(steps=[\n",
    "    ('preprocessor', preprocessor),\n",
    "    ('regressor', LinearRegression())\n",
    "])\n",
    "\n",
    "# Train the model\n",
    "lr_pipeline.fit(X_train, Y_train)\n",
    "\n",
    "# Make predictions and evaluate\n",
    "y_pred_lr = lr_pipeline.predict(X_test)\n",
    "print(\"--- Linear Regression ---\")\n",
    "print(f\"R2 Score: {r2_score(Y_test, y_pred_lr):.4f}\")\n",
    "print(f\"Mean Absolute Error: {mean_absolute_error(Y_test, y_pred_lr):.4f}\\n\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e6cc4acf",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# --- Visualization for Linear Regression ---\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(x=Y_test, y=y_pred_lr, alpha=0.6)\n",
    "plt.plot([min(Y_test), max(Y_test)], [min(Y_test), max(Y_test)], color='red', linestyle='--', lw=2)\n",
    "plt.title('Linear Regression: Actual vs. Predicted Prices')\n",
    "plt.xlabel('Actual Price (Log Transformed)')\n",
    "plt.ylabel('Predicted Price (Log Transformed)')\n",
    "plt.show()"
   ]
  },

      "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[196]\u001b[39m\u001b[32m, line 3\u001b[39m, in \u001b[36mextract_ram_weight_information\u001b[39m\u001b[34m(df)\u001b[39m\n\u001b[32m      2\u001b[39m \u001b[38;5;28;01mdef\u001b[39;00m\u001b[38;5;250m \u001b[39m\u001b[34mextract_ram_weight_information\u001b[39m(df):\n\u001b[32m----> \u001b[39m\u001b[32m3\u001b[39m     \u001b[38;5;28;01mif\u001b[39;00m \u001b[43mdf\u001b[49m\u001b[43m[\u001b[49m\u001b[33;43m'\u001b[39;49m\u001b[33;43mRam\u001b[39;49m\u001b[33;43m'\u001b[39;49m\u001b[43m]\u001b[49m.dtype == \u001b[38;5;28mobject\u001b[39m:  \u001b[38;5;66;03m# Only convert if still a string\u001b[39;00m\n\u001b[32m      4\u001b[39m         df[\u001b[33m'\u001b[39m\u001b[33mRam\u001b[39m\u001b[33m'\u001b[39m] = df[\u001b[33m'\u001b[39m\u001b[33mRam\u001b[39m\u001b[33m'\u001b[39m].str.replace(\u001b[33m'\u001b[39m\u001b[33mGB\u001b[39m\u001b[33m'\u001b[39m, \u001b[33m'\u001b[39m\u001b[33m'\u001b[39m).astype(\u001b[38;5;28mint\u001b[39m)\n\u001b[32m      5\u001b[39m     \u001b[38;5;28;01mif\u001b[39;00m df[\u001b[33m'\u001b[39m\u001b[33mWeight\u001b[39m\u001b[33m'\u001b[39m].dtype == \u001b[38;5;28mobject\u001b[39m:  \u001b[38;5;66;03m# Only convert if still a string\u001b[39;00m\n",
      "\u001b[31mTypeError\u001b[39m: 'NoneType' object is not subscriptable"
     ]
    }
   ],
   "source": [
    "# Turning Ram & Weight columns into numerical values\n",
    "def extract_ram_weight_information(df):\n",
    "    if df['Ram'].dtype == object:  # Only convert if still a string\n",
    "        df['Ram'] = df['Ram'].str.replace('GB', '').astype(int)\n",
    "    if df['Weight'].dtype == object:  # Only convert if still a string\n",
    "        df['Weight'] = df['Weight'].str.replace('kg', '').astype(float)\n",
    "    \n",
    "    # Only rename if they haven't been renamed yet\n",
    "    if 'Ram' in df.columns:\n",
    "        df.rename(columns={'Ram': 'RAM(GB)', 'Weight': 'Weight(kg)'}, inplace=True)\n",
    "    \n",
    "    return df\n",
    "\n",
    "df = extract_ram_weight_information(df)\n",
    "df.head()\n"
   ]
  },

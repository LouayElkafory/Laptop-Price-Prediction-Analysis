   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e8c3d0f4",
   "metadata": {
    "id": "e8c3d0f4"
   },
   "outputs": [
    {
     "ename": "NameError",
     "evalue": "name 'best_rf_model' is not defined",
     "output_type": "error",
     "traceback": [

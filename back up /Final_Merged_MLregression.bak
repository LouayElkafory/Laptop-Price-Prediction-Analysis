  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b536b88c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- XGBoost Report ---\n",
      "R2 Score: 0.8743\n",
      "Mean Absolute Error: 0.1602\n",
      "Root Mean Squared Error: 0.2193\n",
      "\n"
     ]
    },
    {
     "data": {
      "image/png": "",

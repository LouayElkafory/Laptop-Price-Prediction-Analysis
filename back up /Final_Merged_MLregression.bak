   "cell_type": "code",
   "execution_count": null,
   "id": "c9397d8d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<StringArray>\n",
       "[       'macOS',        'No OS',   'Windows 10',     'Mac OS X',\n",
       "        'Linux', 'Windows 10 S',    'Chrome OS',    'Windows 7']\n",
       "Length: 8, dtype: str"
      ]
     },
     "execution_count": 117,
     "metadata": {},
     "output_type": "execute_result"
    }

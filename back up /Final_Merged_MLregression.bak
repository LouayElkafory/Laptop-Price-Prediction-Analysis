  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ec3b374c",
   "metadata": {},
   "outputs": [],
   "source": [
    "if 'OpSys' in df.columns:\n",
    "    def cat_os(inp):\n",
    "        if inp == 'Windows 10' or inp == 'Windows 7' or inp == 'Windows 10 S':\n",
    "            return 'Windows'\n",
    "        elif inp == 'macOS' or inp == 'Mac OS X':\n",
    "            return 'Mac'\n",
    "        elif inp == 'Linux':\n",
    "            return 'Linux'\n",
    "        else:\n",
    "            return inp\n",
    "    df['OpSys'] = df['OpSys'].apply(cat_os)"
   ]
  },

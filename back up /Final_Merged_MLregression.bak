  {
   "cell_type": "code",
   "execution_count": 175,
   "id": "31047797",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define a function to extract the GPU information\n",
    "def extract_GPU_info(df):\n",
    "  df['Gpu_company'] = df['Gpu'].str.extract(r'^(\\w+)')\n",
    "  df['Gpu_Type']= df['Gpu'].str.replace(r'^(\\w+)', '', regex=True)\n",
    "  df.drop(columns=['Gpu'], inplace=True)\n",
    "  return df\n",
    "  \n",
    "  \n",
    "df1 = extract_GPU_info(df)"
   ]
  },

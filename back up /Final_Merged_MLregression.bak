  {
   "cell_type": "markdown",
   "id": "a1b9b9ab",
   "metadata": {},
   "source": [
    "## 3- visualizing data "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b8953530",
   "metadata": {
    "id": "b8953530"
   },
   "source": [
    "## 3-Visualization and finding correlations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "Ev7XTNzZrSUL",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 1000
    },
    "id": "Ev7XTNzZrSUL",
    "outputId": "4a0775f3-3a25-40b8-ca10-2e66f4f31efe"
   },
   "outputs": [],
   "source": [
    "import plotly.express as px\n",
    "\n",
    "categorical_cols = [\n",
    "    'Company', 'TypeName', 'Cpu_Company', 'Cpu_Type',\n",
    "    'First_memory_type', 'Gpu_company', 'Gpu_Type',\n",
    "    'OpSys', 'Resolution'\n",
    "]\n",
    "\n",
    "for col in categorical_cols:\n",
    "    counts = df[col].value_counts().reset_index()\n",
    "    counts.columns = [col, \"count\"]   # \u0625\u0639\u0627\u062f\u0629 \u062a\u0633\u0645\u064a\u0629 \u0627\u0644\u0623\u0639\u0645\u062f\u0629\n",
    "\n",
    "    fig = px.bar(\n",
    "        counts,\n",
    "        x=col,\n",
    "        y=\"count\",\n",
    "        color=col,\n",
    "        title=f\"Distribution of {col}\",\n",
    "        height=500\n",
    "    )\n",
    "    fig.update_layout(\n",
    "        xaxis={'categoryorder': 'total descending'},\n",
    "        showlegend=False\n",
    "    )\n",
    "    fig.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ab1f3cfc",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 1000
    },
    "id": "ab1f3cfc",
    "outputId": "22fb66e5-1fa5-43c2-9e23-1046b157e4f7"
   },

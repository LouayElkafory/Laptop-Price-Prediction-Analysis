  {
   "cell_type": "markdown",
   "id": "v6LBvpGhbMXC",
   "metadata": {
    "id": "v6LBvpGhbMXC"
   },
   "source": [
    "AS We see there is alot of outliers specially in the prices feature"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 163,
   "id": "pMkdiw_dbVqG",
   "metadata": {
    "id": "pMkdiw_dbVqG"
   },
   "outputs": [],
   "source": [
    "# Price\n",
    "Q1 = df['Price_euros'].quantile(0.25)\n",
    "Q3 = df['Price_euros'].quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "lower = Q1 - 1.5*IQR\n",
    "upper = Q3 + 1.5*IQR\n",
    "\n",
    "df = df[(df['Price_euros'] >= lower) & (df['Price_euros'] <= upper)]\n",
    "\n",
    "# Inches\n",
    "Q1_i = df['Inches'].quantile(0.25)\n",
    "Q3_i = df['Inches'].quantile(0.75)\n",
    "IQR_i = Q3_i - Q1_i\n",
    "lower_i = Q1_i - 1.5*IQR_i\n",
    "upper_i = Q3_i + 1.5*IQR_i\n",
    "\n",
    "df = df[(df['Inches'] >= lower_i) & (df['Inches'] <= upper_i)]\n"
   ]
  },

  {
   "cell_type": "markdown",
   "id": "8656140c",
   "metadata": {
    "id": "8656140c"
   },
   "source": [
    ":-Due to the high number of missing values because not all laptops have a secondary hard drive, We will be dropping this column"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 188,
   "id": "c511a063",
   "metadata": {
    "id": "c511a063"
   },
   "outputs": [],
   "source": [
    "df.drop(columns = ['Second_memory_type'], inplace = True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 189,
   "id": "a287859d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def convert_to_gb1(First_memory_value):\n",
    "    if 'TB' in First_memory_value:\n",
    "        return float(First_memory_value.replace('TB', '').strip()) * 1024 \n",
    "    if 'GB' in First_memory_value:\n",
    "        return float(First_memory_value.replace('GB', '').strip())\n",
    "    return None \n",
    "    \n",
    "def convert_to_gb2(Second_memory_value):\n",
    "    if  pd.isna(Second_memory_value):\n",
    "        return 0.0\n",
    "    if 'TB' in Second_memory_value:\n",
    "        return float(Second_memory_value.replace('TB', '').strip()) * 1024  \n",
    "    if 'GB' in Second_memory_value:\n",
    "        return float(Second_memory_value.replace('GB', '').strip())  \n",
    "    return None  \n",
    "\n",
    "df['First_memory_volume'] = df['First_memory_volume'].apply(convert_to_gb1)\n",
    "df['Second_memory_volume'] = df['Second_memory_volume'].apply(convert_to_gb2)\n",
    "df.rename(columns={ 'First_memory_volume' :'First_memory_volume(GB)', 'Second_memory_volume' :'Second_memory_volume(GB)'}, inplace=True)"
   ]
  },

    }
   ],
   "source": [
    "#removing dups\n",
    "\n",
    "def remove_dups(df):\n",
    "    dups = df.duplicated().sum()\n",
    "    if(dups):\n",
    "        print(f'duplicated values: {df.duplicated().sum()}')\n",
    "        df = df.drop_duplicates(inplace= True)\n",
    "    else:\n",
    "        print(f'There is 0 duplicates')\n",
    "    return df\n",
    "\n",
    "remove_dups(df)\n",
    "df.duplicated().sum()\n"
   ]
  },

   "source": [
    "from xgboost import XGBRegressor\n",
    "\n",
    "# Create the pipeline\n",
    "xgb_pipeline = Pipeline(steps=[\n",
    "    ('preprocessor', preprocessor),\n",
    "    ('regressor', XGBRegressor(random_state=2))\n",
    "])\n",
    "\n",
    "# Train the model\n",
    "xgb_pipeline.fit(X_train, Y_train)\n",
    "\n",
    "# Make predictions\n",
    "y_pred_xgb = xgb_pipeline.predict(X_test)\n",
    "\n",
    "# --- XGBoost Report ---\n",
    "xgb_r2 = r2_score(Y_test, y_pred_xgb)\n",
    "xgb_mae = mean_absolute_error(Y_test, y_pred_xgb)\n",
    "xgb_rmse = np.sqrt(mean_squared_error(Y_test, y_pred_xgb))\n",
    "\n",
    "print(\"--- XGBoost Report ---\")\n",
    "print(f\"R2 Score: {xgb_r2:.4f}\")\n",
    "print(f\"Mean Absolute Error: {xgb_mae:.4f}\")\n",
    "print(f\"Root Mean Squared Error: {xgb_rmse:.4f}\\n\")\n",
    "\n",
    "\n",
    "# --- Visualization for XGBoost ---\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(x=Y_test, y=y_pred_xgb, alpha=0.6)\n",
    "plt.plot([min(Y_test), max(Y_test)], [min(Y_test), max(Y_test)], color='red', linestyle='--', lw=2)\n",
    "plt.title('XGBoost: Actual vs. Predicted Prices')\n",
    "plt.xlabel('Actual Price (Log Transformed)')\n",
    "plt.ylabel('Predicted Price (Log Transformed)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "886de5af",
   "metadata": {},
   "source": [
    "## 2- Gradient Boosting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e8b13a09",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- Gradient Boosting Report ---\n",
      "R2 Score: 0.8769\n",
      "Mean Absolute Error: 0.1743\n",
      "Root Mean Squared Error: 0.2170\n",
      "\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "from sklearn.ensemble import GradientBoostingRegressor\n",
    "\n",
    "# Create the pipeline\n",
    "gbr_pipeline = Pipeline(steps=[\n",
    "    ('preprocessor', preprocessor),\n",
    "    ('regressor', GradientBoostingRegressor(random_state=2))\n",
    "])\n",
    "\n",
    "# Train the model\n",
    "gbr_pipeline.fit(X_train, Y_train)\n",
    "\n",
    "# Make predictions\n",
    "y_pred_gbr = gbr_pipeline.predict(X_test)\n",
    "\n",
    "# --- Gradient Boosting Report ---\n",
    "gbr_r2 = r2_score(Y_test, y_pred_gbr)\n",
    "gbr_mae = mean_absolute_error(Y_test, y_pred_gbr)\n",
    "gbr_rmse = np.sqrt(mean_squared_error(Y_test, y_pred_gbr))\n",
    "\n",
    "print(\"--- Gradient Boosting Report ---\")\n",
    "print(f\"R2 Score: {gbr_r2:.4f}\")\n",
    "print(f\"Mean Absolute Error: {gbr_mae:.4f}\")\n",
    "print(f\"Root Mean Squared Error: {gbr_rmse:.4f}\\n\")\n",
    "\n",
    "# --- Visualization for Gradient Boosting ---\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(x=Y_test, y=y_pred_gbr, alpha=0.6)\n",
    "plt.plot([min(Y_test), max(Y_test)], [min(Y_test), max(Y_test)], color='red', linestyle='--', lw=2)\n",
    "plt.title('Gradient Boosting: Actual vs. Predicted Prices')\n",
    "plt.xlabel('Actual Price (Log Transformed)')\n",
    "plt.ylabel('Predicted Price (Log Transformed)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3a295fcb",
   "metadata": {},
   "source": [
    "## Evaluation"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bee1527c",
   "metadata": {
    "id": "bee1527c"
   },
   "source": [
    "# Select and train a model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "117a92e2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- Model Regression Report ---\n",
      "                     R2 Score       MAE      RMSE\n",
      "Random Forest        0.888686  0.154760  0.206357\n",
      "K-Nearest Neighbors  0.801429  0.207629  0.275615\n",
      "Linear Regression    0.777306  0.235192  0.291876\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "from sklearn.metrics import mean_squared_error\n",
    "\n",
    "# Create a dictionary to store the results for the selected models\n",
    "results = {}\n",
    "\n",
    "# --- Linear Regression Report ---\n",
    "lr_r2 = r2_score(Y_test, y_pred_lr)\n",
    "lr_mae = mean_absolute_error(Y_test, y_pred_lr)\n",
    "lr_rmse = np.sqrt(mean_squared_error(Y_test, y_pred_lr))\n",
    "results[\"Linear Regression\"] = (lr_r2, lr_mae, lr_rmse)\n",
    "\n",
    "# --- Random Forest Report ---\n",
    "rf_r2 = r2_score(Y_test, y_pred_rf)\n",
    "rf_mae = mean_absolute_error(Y_test, y_pred_rf)\n",
    "rf_rmse = np.sqrt(mean_squared_error(Y_test, y_pred_rf))\n",
    "results[\"Random Forest\"] = (rf_r2, rf_mae, rf_rmse)\n",
    "\n",
    "# --- K-Nearest Neighbors Report ---\n",
    "knn_r2 = r2_score(Y_test, y_pred_knn)\n",
    "knn_mae = mean_absolute_error(Y_test, y_pred_knn)\n",
    "knn_rmse = np.sqrt(mean_squared_error(Y_test, y_pred_knn))\n",
    "results[\"K-Nearest Neighbors\"] = (knn_r2, knn_mae, knn_rmse)\n",
    "\n",
    "\n",
    "# Create a DataFrame for comparison\n",
    "results_df = pd.DataFrame(results, index=['R2 Score', 'MAE', 'RMSE']).T.sort_values(by='R2 Score', ascending=False)\n",
    "\n",
    "print(\"--- Model Regression Report ---\")\n",
    "print(results_df)\n",
    "\n",
    "# Visualize the R2 Score\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.barplot(x=results_df.index, y=results_df['R2 Score'])\n",
    "plt.title('Model R2 Score (Accuracy) Comparison')\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0b2bf277",
   "metadata": {
    "id": "0b2bf277"
   },
   "source": [
    "better evaluation using Cross validation\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "da1518af",
   "metadata": {
    "id": "da1518af"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Validating Linear Regression...\n",
      "Linear Regression:\n",
      "  RMSE (CV): 0.2899\n",
      "  R2 Score (CV): 0.7508\n",
      "\n",
      "\n",
      "Validating SVM ...\n",
      "SVM :\n",
      "  RMSE (CV): 0.2114\n",
      "  R2 Score (CV): 0.8675\n",
      "\n",
      "\n",
      "Validating Random Forest...\n",
      "Random Forest:\n",
      "  RMSE (CV): 0.2024\n",
      "  R2 Score (CV): 0.8779\n",
      "\n",
      "\n",
      "Evaluation Summary:\n",
      "Linear Regression: RMSE (CV)= 0.2899,R2 Score (CV) = 0.7508\n",
      "SVM : RMSE (CV)= 0.2114,R2 Score (CV) = 0.8675\n",
      "Random Forest: RMSE (CV)= 0.2024,R2 Score (CV) = 0.8779\n"
     ]
    }
   ],
   "source": [
    "# custom RMSE scorer\n",
    "def rmse_scorer(y_true, y_pred):\n",
    "    return np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "\n",
    "# Create the scorer object\n",
    "rmse_scorer_cv = make_scorer(rmse_scorer, greater_is_better=False)\n",
    "\n",
    "# Define models\n",
    "models = {\n",
    "    \"Linear Regression\": LinearRegression(),\n",
    "    \"SVM \":svm.SVR(),\n",
    "    \"Random Forest\": RandomForestRegressor(random_state=42)\n",
    "}\n",
    "\n",
    "# Dictionary to store results\n",
    "results = {}\n",
    "\n",
    "# Train and evaluate models\n",
    "for name, model in models.items():\n",
    "    print(f\"Validating {name}...\")\n",
    "\n",
    "    # Cross-validation for RMSE\n",
    "    cv_rmse = -cross_val_score(\n",
    "        model,\n",
    "        x_train_preprocessed,\n",
    "        y_train,\n",
    "        scoring=rmse_scorer_cv,\n",
    "        cv=10\n",
    "    ).mean()\n",
    "\n",
    "    # Cross-validation for R2\n",
    "    cv_r2 = cross_val_score(\n",
    "        model,\n",
    "        x_train_preprocessed,\n",
    "        y_train,\n",
    "        scoring='r2',\n",
    "        cv=10\n",
    "    ).mean()\n",
    "\n",
    "    # Store results\n",
    "    results[name] = {\n",
    "        \"RMSE (CV)\": cv_rmse,\n",
    "        \"R2 Score (CV)\": cv_r2\n",
    "    }\n",
    "\n",
    "    # Display individual model results\n",
    "    print(f\"{name}:\")\n",
    "    print(f\"  RMSE (CV): {cv_rmse:.4f}\")\n",
    "    print(f\"  R2 Score (CV): {cv_r2:.4f}\")\n",
    "    print(\"\\n\")\n",
    "\n",
    "# Summary\n",
    "print(\"Evaluation Summary:\")\n",
    "for name, metrics in results.items():\n",
    "    print(f\"{name}: RMSE (CV)= {metrics['RMSE (CV)']:.4f},R2 Score (CV) = {metrics['R2 Score (CV)']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6cf5ccfa",
   "metadata": {
    "id": "6cf5ccfa"
   },
   "source": [
    "Although the random forest has clearly overfit the data we believe it is due to the low number of instances but Based on that and cross validation score, we will be using the random forest regressor hoping for better results on the test set after hyperparameter tuning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9860df18",
   "metadata": {
    "id": "9860df18"
   },
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "labels = ['Training', 'Cross-Validation']\n",
    "r2_scores_randomforest = [r2_train, cv_r2 ]\n",
    "mse_scores_randomforest = [rmse_train, cv_rmse]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "x = np.arange(len(labels))\n",
    "width = 0.35\n",
    "bars_r2_randomforest = ax.bar(x - width / 2, r2_scores_randomforest, width, label='R\u00b2 Score', color='skyblue')\n",
    "bars_mse_randomforest = ax.bar(x + width / 2, mse_scores_randomforest, width, label='MSE', color='salmon')\n",
    "\n",
    "ax.set_xlabel('Model Type')\n",
    "ax.set_ylabel('Scores')\n",
    "ax.set_title('Random foresst: Training vs Cross-Validation Comparison')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(labels)\n",
    "ax.legend()\n",
    "\n",
    "def add_value_labels(bars):\n",
    "    for bar in bars:\n",
    "        yval = bar.get_height()\n",
    "        ax.text(bar.get_x() + bar.get_width() / 2, yval, f'{yval:.4f}', ha='center', va='bottom')\n",
    "\n",
    "add_value_labels(bars_r2_randomforest)\n",
    "add_value_labels(bars_mse_randomforest)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a80e4ebc",
   "metadata": {
    "id": "a80e4ebc"
   },
   "source": [
    "# hyperparameter tuning\n",
    "\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9d449f1e",
   "metadata": {
    "id": "9d449f1e"
   },
   "source": [
    "Evaluation on testset before hyperparameter tuning the model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b966b31c",
   "metadata": {
    "id": "b966b31c"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Starting hyperparameter tuning...\n",
      "Fitting 5 folds for each of 216 candidates, totalling 1080 fits\n",
      "\n",
      "Best Hyperparameters:\n",
      "{'bootstrap': True, 'max_depth': None, 'min_samples_leaf': 1, 'min_samples_split': 2, 'n_estimators': 100}\n"
     ]
    }
   ],
   "source": [
    "# Define the parameter grid\n",
    "param_grid = {\n",
    "    'n_estimators': [50, 100, 200],\n",
    "    'max_depth': [None, 10, 20, 30],\n",
    "    'min_samples_split': [2, 5, 10],\n",
    "    'min_samples_leaf': [1, 2, 4],\n",
    "    'bootstrap': [True, False]\n",
    "}\n",
    "\n",
    "# Initialize the Random Forest Regressor\n",
    "rf = RandomForestRegressor(random_state=42)\n",
    "\n",
    "# Use custom scoring for RMSE and R\u00b2\n",
    "scoring = {\n",
    "    'RMSE': 'neg_mean_squared_error',\n",
    "    'R2': make_scorer(r2_score)\n",
    "}\n",
    "\n",
    "# Initialize GridSearchCV\n",
    "grid_search = GridSearchCV(\n",
    "    estimator=rf,\n",
    "    param_grid=param_grid,\n",
    "    scoring=scoring,\n",
    "    refit='R2',\n",
    "    cv=5,\n",
    "    verbose=2,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "# Perform the grid search\n",
    "print(\"Starting hyperparameter tuning...\")\n",
    "grid_search.fit(x_train_preprocessed, y_train)\n",
    "\n",
    "# Extract best parameters, RMSE, and R\u00b2\n",
    "best_params = grid_search.best_params_\n",
    "best_rmse = np.sqrt(-grid_search.cv_results_['mean_test_RMSE'][grid_search.best_index_])  # Convert negative MSE to RMSE\n",
    "best_r2 = grid_search.best_score_  # R\u00b2 Score is directly available\n",
    "\n",
    "print(\"\\nBest Hyperparameters:\")\n",
    "print(best_params)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c2d0e6f5",
   "metadata": {
    "id": "c2d0e6f5"
   },
   "source": [
    "Final model = RandomForestRegressor"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "31e84075",
   "metadata": {
    "id": "31e84075"
   },
   "outputs": [
    {
     "ename": "NameError",
     "evalue": "name 'RandomForestRegressor' is not defined",
     "output_type": "error",
     "traceback": [
      "\u001b[31m---------------------------------------------------------------------------\u001b[39m",
      "\u001b[31mNameError\u001b[39m                                 Traceback (most recent call last)",
      "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[8]\u001b[39m\u001b[32m, line 2\u001b[39m\n\u001b[32m      1\u001b[39m \u001b[38;5;66;03m# Initialize the model with the best hyperparameters\u001b[39;00m\n\u001b[32m----> \u001b[39m\u001b[32m2\u001b[39m best_rf_model = \u001b[43mRandomForestRegressor\u001b[49m(\n\u001b[32m      3\u001b[39m     bootstrap=\u001b[38;5;28;01mTrue\u001b[39;00m,\n\u001b[32m      4\u001b[39m     max_depth=\u001b[38;5;28;01mNone\u001b[39;00m,  \u001b[38;5;66;03m# No limit on tree depth\u001b[39;00m\n\u001b[32m      5\u001b[39m     min_samples_leaf=\u001b[32m1\u001b[39m,\n\u001b[32m      6\u001b[39m     min_samples_split=\u001b[32m2\u001b[39m,\n\u001b[32m      7\u001b[39m     n_estimators=\u001b[32m100\u001b[39m,\n\u001b[32m      8\u001b[39m     random_state=\u001b[32m42\u001b[39m\n\u001b[32m      9\u001b[39m )\n\u001b[32m     11\u001b[39m \u001b[38;5;66;03m# Fit the model on the full training dataset\u001b[39;00m\n\u001b[32m     12\u001b[39m best_rf_model.fit(x_train_preprocessed, y_train)\n",
      "\u001b[31mNameError\u001b[39m: name 'RandomForestRegressor' is not defined"
     ]
    }
   ],
   "source": [
    "# Initialize the model with the best hyperparameters\n",
    "best_rf_model = RandomForestRegressor(\n",
    "    bootstrap=True,\n",
    "    max_depth=None,  # No limit on tree depth\n",
    "    min_samples_leaf=1,\n",
    "    min_samples_split=2,\n",
    "    n_estimators=100,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "# Fit the model on the full training dataset\n",
    "best_rf_model.fit(x_train_preprocessed, y_train)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6faf726a",
   "metadata": {
    "id": "6faf726a"
   },
   "source": [
    "-Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1e5c8d17",

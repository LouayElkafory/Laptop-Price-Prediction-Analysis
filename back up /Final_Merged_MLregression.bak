      "[0 1]\n"
     ]
    }
   ],
   "source": [
    "for col in categorical_features:\n",
    "    print(f\"\\nValue counts for {col}:\\n{df[col].value_counts()}\")\n",
    "    print(f\"\\nUnique values for {col}:\\n{df[col].unique()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a100d8ba",
   "metadata": {
    "id": "a100d8ba"
   },
   "source": [
    "## 5- Transforming the price label due to the skewness seen earlier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9027c1a8",
   "metadata": {
    "id": "9027c1a8"
   },
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x300 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "fig, axs = plt.subplots(1, 2, figsize=(8, 3), sharey=True)\n",
    "df[\"Price_euros\"].hist(ax=axs[0], bins=50)\n",
    "df[\"Price_euros\"].apply(np.log).hist(ax=axs[1], bins=50)\n",
    "axs[0].set_xlabel(\"Price_euros\")\n",
    "axs[1].set_xlabel(\"Log of Price_euros\")\n",
    "axs[0].set_ylabel(\"frequency\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "54f9e0a8",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
    "\n",
    "# Prepare the data for modeling\n",
    "X = df.drop(columns=['Price_euros', 'Cpu_Type', 'Gpu_Type']) # Drop Cpu_Type and Gpu_type as they have too many categories\n",
    "Y = np.log(df['Price_euros']) # Log transform the target variable\n",
    "\n",
    "X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.15, random_state=2)\n",
    "\n",
    "# Define categorical and numerical features\n",
    "categorical_features = [\n",
    "    'Company',\n",
    "    'TypeName',\n",
    "    'Cpu_Company',\n",
    "    'First_memory_type',\n",
    "    'OpSys',\n",
    "    'Gpu_company']\n",
    "\n",
    "numerical_features = [\n",
    "    'Inches',\n",
    "    'RAM(GB)',\n",
    "    'Weight(kg)',\n",
    "    'Touchscreen',\n",
    "    'X_res',\n",
    "    'Y_res',\n",
    "    'Cpu_Freq(GHz)',\n",
    "    'First_memory_volume(GB)',\n",
    "    'Second_memory_volume(GB)']\n",
    "\n",
    "# Create the preprocessing pipeline\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', StandardScaler(), numerical_features),\n",
    "        ('cat', OneHotEncoder(handle_unknown='ignore'), categorical_features)\n",
    "    ],\n",
    "    remainder='passthrough'\n",
    ")"
   ]
  },

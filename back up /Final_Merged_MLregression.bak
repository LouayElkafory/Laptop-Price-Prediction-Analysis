  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d25f87c0",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 871
    },
    "id": "d25f87c0",
    "outputId": "d2009271-461b-4492-ccab-58a978efe066"
   },
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Specify only numeric columns\n",
    "numerical_cols = df.select_dtypes(include=['number'])\n",
    "\n",
    "# Correlation coefficient\n",
    "correlation_matrix = numerical_cols.corr()\n",
    "\n",
    "# heatmap to see the relationships.\n",
    "plt.figure(figsize=(12, 8))\n",
    "sns.heatmap(correlation_matrix, annot=True, cmap='crest', fmt='.2f')\n",
    "plt.title(\"Correlation Heatmap\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d2096ce1",
   "metadata": {},
   "source": [
    "# spiltting the data and Applying\n",
